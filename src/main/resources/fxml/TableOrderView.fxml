<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.restaurant.pos.ui.controller.TableOrderController">

    <top>
        <Label fx:id="tableLabel" text="Стол" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    </top>

    <left>
        <VBox spacing="8" prefWidth="260">
            <Label text="Меню" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <ListView fx:id="menuList" prefHeight="600"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="8">
            <Label text="Заказ" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TableView fx:id="orderTable" prefHeight="600"/>
        </VBox>
    </center>

    <right>
        <VBox spacing="12" prefWidth="240">
            <Label fx:id="totalLabel" text="Итого: ₽ 0.00" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Button fx:id="addDishButton" text="Добавить блюдо" maxWidth="1.7976931348623157E308"/>
            <Button fx:id="closeOrderButton" text="Закрыть заказ" maxWidth="1.7976931348623157E308"/>
            <Button fx:id="backButton" text="Назад к столам" maxWidth="1.7976931348623157E308"/>
        </VBox>
    </right>

</BorderPane>

